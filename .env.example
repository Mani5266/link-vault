# ============================================================
# LinkVault — Environment Variables
# ============================================================
# Copy this file to set up your environment:
#   Frontend: apps/web/.env.local
#   Backend:  apps/api/.env
# ============================================================

# === Frontend (apps/web/.env.local) ===========================

# Supabase project URL (from Supabase dashboard > Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase anon/public key (safe for client-side)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Backend API URL
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1


# === Backend (apps/api/.env) ==================================

# Server port
PORT=4000

# Environment
NODE_ENV=development

# Google Gemini API key (get from https://aistudio.google.com/apikey)
GEMINI_API_KEY=your-gemini-api-key-here

# Supabase project URL
SUPABASE_URL=https://your-project-id.supabase.co

# Supabase service role key (NEVER expose client-side)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Allowed CORS origins (comma-separated for multiple)
CORS_ORIGIN=http://localhost:3000

# AI rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=10

# Sentry DSN for error tracking (optional — leave empty to disable)
SENTRY_DSN=


# === Sentry (optional — only needed for production) ===========

# Sentry DSN for Next.js frontend (set in apps/web/.env.local)
NEXT_PUBLIC_SENTRY_DSN=

# Sentry org and project slugs (used by @sentry/nextjs for source maps)
SENTRY_ORG=
SENTRY_PROJECT=

# Sentry auth token for source map uploads (used at build time)
# Generate at: https://sentry.io/orgredirect/organizations/:orgslug/settings/auth-tokens/
SENTRY_AUTH_TOKEN=
